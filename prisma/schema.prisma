// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "../src/service/prisma/generated"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(uuid())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  email      String      @unique
  phone      String?
  firstName  String?
  lastName   String?
  birthday   DateTime?
  handedness Handedness?
  gloveHand  GloveHand?
  archivedAt DateTime?
  role       Role        @default(PLAYER)
  seasons    Player[]
  emailSends EmailSend[]
}

enum Role {
  PLAYER
  MANAGER
  ADMIN
}

enum Handedness {
  LEFT
  RIGHT
}

enum GloveHand {
  LEFT
  RIGHT
}

model League {
  id          String   @id @default(uuid())
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  description String?
  skillLevel  String?
  seasons     Season[]
}

model Season {
  id            String         @id @default(uuid())
  slug          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  league        League         @relation(fields: [leagueId], references: [id])
  leagueId      String
  name          String
  info          String?
  startDate     DateTime
  endDate       DateTime
  sundays       Boolean        @default(false)
  mondays       Boolean        @default(false)
  tuesdays      Boolean        @default(false)
  wednesdays    Boolean        @default(false)
  thursdays     Boolean        @default(false)
  fridays       Boolean        @default(false)
  saturdays     Boolean        @default(false)
  players       Player[]
  teams         Team[]
  games         Game[]
  draft         DraftPick[]
  registrations Registration[]

  @@unique([leagueId, slug])
}

model Team {
  id             String      @id @default(uuid())
  slug           String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  season         Season      @relation(fields: [seasonId], references: [id])
  seasonId       String
  name           String
  abbreviation   String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  manager        Player?     @relation(fields: [managerId], references: [id])
  managerId      String?     @unique
  players        Player[]    @relation("TeamPlayers")
  homeGames      Game[]      @relation("HomeTeam")
  awayGames      Game[]      @relation("AwayTeam")
  goals          Goal[]
  goalsAgainst   GoalAgainst[]
  penalties      Penalty[]
  draftPicks     DraftPick[]
  lineups        Lineup[]
  standing       Standing?

  @@unique([seasonId, slug])
}

view Standing {
  teamId       String @unique
  rank         Int
  team         Team   @relation(fields: [teamId], references: [id])
}

model Player {
  id                 String         @id @default(uuid())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id])
  userId             String
  season             Season         @relation(fields: [seasonId], references: [id])
  seasonId           String
  classification     Classification @default(ROSTER)
  status             Status         @default(ACTIVE)
  managedTeam        Team?
  team               Team?          @relation("TeamPlayers", fields: [teamId], references: [id])
  teamId             String?
  position           Position?
  number             Int?
  playerRating       Float?
  goalieRating       Float?
  lockerRating       Float?
  registrationNumber String?
  ratingVerified     Boolean        @default(false)
  confirmed          Boolean?
  paid               Decimal        @default(0) @db.Decimal(10, 2)
  goals              Goal[]         @relation("Scorer")
  primaryAssists     Goal[]         @relation("PrimaryAssist")
  secondaryAssists   Goal[]         @relation("SecondaryAssist")
  penalties          Penalty[]
  draftPick          DraftPick?
  lineups            Lineup[]
}

enum Classification {
  ROSTER
  SUBSTITUTE
}

enum Status {
  ACTIVE
  INJURED
  SUSPENDED
}

enum Position {
  G
  D
  D_F
  F
  F_D
}

model Game {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  season         Season    @relation(fields: [seasonId], references: [id])
  seasonId       String
  round          Int
  datetime       DateTime
  location       String
  homeTeam       Team?     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId     String?
  homeTeamResult Result?
  homeTeamPoints Int?
  awayTeam       Team?     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId     String?
  awayTeamResult Result?
  awayTeamPoints Int?
  goals          Goal[]
  penalties      Penalty[]
  lineups        Lineup[]
}

enum Result {
  WIN
  LOSS
  TIE
}

model Goal {
  id                String   @id @default(uuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  game              Game     @relation(fields: [gameId], references: [id])
  gameId            String
  period            Int
  time              Int
  strength          Strength
  team              Team     @relation(fields: [teamId], references: [id])
  teamId            String
  scorer            Player   @relation("Scorer", fields: [scorerId], references: [id])
  scorerId          String
  primaryAssist     Player?  @relation("PrimaryAssist", fields: [primaryAssistId], references: [id])
  primaryAssistId   String?
  secondaryAssist   Player?  @relation("SecondaryAssist", fields: [secondaryAssistId], references: [id])
  secondaryAssistId String?
}

view GoalAgainst {
  id                String   @unique
  createdAt         DateTime
  updatedAt         DateTime
  gameId            String
  period            Int
  time              Int
  strength          Strength
  teamId            String
  scorerId          String
  primaryAssistId   String?
  secondaryAssistId String?
  team              Team     @relation(fields: [teamId], references: [id])
}

enum Strength {
  EVEN
  POWERPLAY
  SHORTHANDED
  EMPTY_NET
}

model Penalty {
  id        String          @id @default(uuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  game      Game            @relation(fields: [gameId], references: [id])
  gameId    String
  period    Int
  time      Int
  team      Team            @relation(fields: [teamId], references: [id])
  teamId    String
  player    Player          @relation(fields: [playerId], references: [id])
  playerId  String
  category  PenaltyCategory @default(MINOR)
  type      PenaltyType
  minutes   Int
}

model Lineup {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  game      Game     @relation(fields: [gameId], references: [id])
  gameId    String
  team      Team     @relation(fields: [teamId], references: [id])
  teamId    String
  player    Player   @relation(fields: [playerId], references: [id])
  playerId  String
  number    Int?

  @@unique([gameId, playerId])
}

enum PenaltyCategory {
  MINOR
  MAJOR
  MATCH
  MISCONDUCT
  GAME_MISCONDUCT
}

enum PenaltyType {
  ABUSE_OF_OFFICIALS
  BOARDING
  BUTT_ENDING
  CHARGING
  CHECKING_FROM_BEHIND
  CLIPPING
  CROSS_CHECKING
  DELAY_OF_GAME
  ELBOWING
  EMBELLISHMENT
  EQUIPMENT
  FIGHTING
  GOALTENDER_INTERFERENCE
  HANDLING_THE_PUCK
  HEAD_BUTTING
  HIGH_STICKING
  HOLDING
  HOOKING
  ILLEGAL_CHECK_TO_THE_HEAD
  ILLEGAL_SUBSTITUTION
  INTERFERENCE
  KICKING
  KNEEING
  LEAVING_THE_BENCH
  ROUGHING
  SLASHING
  SLEW_FOOTING
  SPEARING
  THROWING_EQUIPMENT
  TOO_MANY_MEN
  TRIPPING
  UNSPORTSMANLIKE_CONDUCT
}

model Registration {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  season         Season         @relation(fields: [seasonId], references: [id])
  seasonId       String
  email          String
  firstName      String?
  lastName       String?
  phone          String?
  birthday       DateTime?
  handedness     Handedness?
  gloveHand      GloveHand?
  position       Position?
  playerRating   Float?
  goalieRating   Float?
  classification Classification @default(ROSTER)
  referral       String?

  @@unique([seasonId, email])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id         String      @id @default(uuid())
  timestamp  DateTime    @default(now())
  requestId  String
  actorId    String?
  actorRole  Role?
  action     AuditAction
  entityType String
  entityId   String
  metadata   Json?
  endpoint   String

  @@index([entityType])
  @@index([actorId])
  @@index([action])
  @@index([timestamp])
}

model DraftPick {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  season       Season   @relation(fields: [seasonId], references: [id])
  seasonId     String
  overall      Int
  round        Int
  pick         Int
  team         Team?    @relation(fields: [teamId], references: [id])
  teamId       String?
  player       Player?  @relation(fields: [playerId], references: [id])
  playerId     String?  @unique
  /// Snapshot of the player's rating at the time of the draft
  playerRating Float?
  /// Snapshot of the goalie's rating at the time of the draft
  goalieRating Float?
}

model EmailSend {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  subject        String
  htmlBody       String
  textBody       String?
  recipientCount Int
  status         String           @default("sent")
  sentAt         DateTime         @default(now())
  sentBy         User             @relation(fields: [sentById], references: [id])
  sentById       String
  recipients     EmailRecipient[]
}

model EmailRecipient {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())
  emailSend   EmailSend @relation(fields: [emailSendId], references: [id])
  emailSendId String
  address     String
  name        String?
  status      String    @default("queued")
}
